rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && (request.auth.token.email == 'freedomtech120@gmail.com' || exists(/databases/$(database)/documents/admins/$(request.auth.uid))); }
    function isOwner(tenantId) { return isSignedIn() && request.auth.uid == tenantId; }

    // Tenants
    match /tenants/{tenantId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(tenantId);
      allow update: if isAdmin() || (isOwner(tenantId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isApproved', 'isAdmin']));
    }

    // Platform Settings
    match /platform/{document=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Admin collection (if needed for additional admins)
    match /admins/{userId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Orders
    match /orders/{orderId} {
      allow list: if isSignedIn() && (resource.data.tenantId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.tenantId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.tenantId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.tenantId == request.auth.uid && request.resource.data.tenantId == request.auth.uid;
      allow delete: if isSignedIn() && (resource.data.tenantId == request.auth.uid || isAdmin());
    }

    // Expenses
    match /expenses/{expenseId} {
      allow list: if isSignedIn() && (resource.data.tenantId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.tenantId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.tenantId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.tenantId == request.auth.uid && request.resource.data.tenantId == request.auth.uid;
      allow delete: if isSignedIn() && (resource.data.tenantId == request.auth.uid || isAdmin());
    }

    // Customers
    match /customers/{customerId} {
      allow list: if isSignedIn() && (resource.data.tenantId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.tenantId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.tenantId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.tenantId == request.auth.uid && request.resource.data.tenantId == request.auth.uid;
      allow delete: if isSignedIn() && (resource.data.tenantId == request.auth.uid || isAdmin());
    }

    // Products
    match /products/{productId} {
      allow list: if isSignedIn() && (resource.data.tenantId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.tenantId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.tenantId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.tenantId == request.auth.uid && request.resource.data.tenantId == request.auth.uid;
      allow delete: if isSignedIn() && (resource.data.tenantId == request.auth.uid || isAdmin());
    }

    // Settings
    match /settings/{tenantId} {
      allow read: if isOwner(tenantId) || isAdmin();
      allow write: if isOwner(tenantId) || isAdmin();
    }
  }
}

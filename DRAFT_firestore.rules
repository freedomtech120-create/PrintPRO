rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Primitives ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }
    
    function isOwner(tenantId) {
      return isSignedIn() && request.auth.uid == tenantId;
    }
    
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'freedomtech120@gmail.com';
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 64 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    // --- Schema Validations ---

    function isValidTenant(data) {
      return data.email is string && data.email.size() <= 100
        && data.name is string && data.name.size() <= 100
        && (!('photoURL' in data) || data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 500))
        && data.subscriptionStatus in ['trial', 'active', 'expired', 'pending_approval'];
    }

    function isValidOrder(data) {
      return data.tenantId is string && data.tenantId.size() <= 128
        && data.customerId is string && data.customerId.size() <= 128
        && data.customerName is string && data.customerName.size() <= 100
        && data.totalAmount is number && data.paidAmount is number
        && data.status in ['pending', 'processing', 'completed', 'delivered', 'cancelled']
        && data.paymentStatus in ['unpaid', 'partial', 'paid']
        && data.items is list && data.items.size() > 0 && data.items.size() <= 50;
    }

    function isValidCustomer(data) {
      return data.tenantId is string && data.tenantId.size() <= 128
        && data.name is string && data.name.size() <= 100
        && (!('email' in data) || data.email == null || (data.email is string && data.email.size() <= 100))
        && (!('phone' in data) || data.phone == null || (data.phone is string && data.phone.size() <= 20));
    }

    function isValidProduct(data) {
      return data.tenantId is string && data.tenantId.size() <= 128
        && data.name is string && data.name.size() <= 100
        && data.pricePerSqFt is number;
    }

    function isValidExpense(data) {
      return data.tenantId is string && data.tenantId.size() <= 128
        && data.description is string && data.description.size() <= 200
        && data.amount is number
        && data.category is string && data.category.size() <= 50;
    }

    function isValidSettings(data) {
      return data.tenantId is string && data.tenantId.size() <= 128
        && data.name is string && data.name.size() <= 100
        && data.invoicePrefix is string && data.invoicePrefix.size() <= 10
        && data.nextInvoiceNumber is number;
    }

    // --- Collection Rules ---

    match /tenants/{tenantId} {
      allow get: if isOwner(tenantId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(tenantId) && isValidTenant(incoming()) 
        && incoming().isApproved == (request.auth.token.email == 'freedomtech120@gmail.com')
        && incoming().subscriptionStatus == 'trial'
        && (!('isAdmin' in incoming()) || incoming().isAdmin == (request.auth.token.email == 'freedomtech120@gmail.com'));
      
      allow update: if (isOwner(tenantId) && isValidTenant(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'photoURL'])
      )) || isAdmin();
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && (isOwner(existing().tenantId) || isAdmin());
      allow list: if isSignedIn() && (isOwner(resource.data.tenantId) || isAdmin());
      allow create: if isSignedIn() && isOwner(incoming().tenantId) && isValidOrder(incoming())
        && isValidId(orderId)
        && existsAfter(/databases/$(database)/documents/settings/$(incoming().tenantId))
        && incoming().createdAt == request.time;
      allow update: if isSignedIn() && (isOwner(existing().tenantId) || isAdmin()) && isValidOrder(incoming())
        && incoming().tenantId == existing().tenantId
        && incoming().updatedAt == request.time
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['status', 'paymentStatus', 'updatedAt'])
          || isAdmin()
        );
      allow delete: if isAdmin();
    }

    match /customers/{customerId} {
      allow get: if isSignedIn() && (isOwner(existing().tenantId) || isAdmin());
      allow list: if isSignedIn() && (isOwner(resource.data.tenantId) || isAdmin());
      allow create: if isSignedIn() && isOwner(incoming().tenantId) && isValidCustomer(incoming())
        && isValidId(customerId);
      allow update: if isSignedIn() && (isOwner(existing().tenantId) || isAdmin()) && isValidCustomer(incoming())
        && incoming().tenantId == existing().tenantId;
      allow delete: if isSignedIn() && (isOwner(existing().tenantId) || isAdmin());
    }

    match /products/{productId} {
      allow get: if isSignedIn() && (isOwner(existing().tenantId) || isAdmin());
      allow list: if isSignedIn() && (isOwner(resource.data.tenantId) || isAdmin());
      allow create: if isSignedIn() && isOwner(incoming().tenantId) && isValidProduct(incoming())
        && isValidId(productId);
      allow update: if isSignedIn() && (isOwner(existing().tenantId) || isAdmin()) && isValidProduct(incoming())
        && incoming().tenantId == existing().tenantId;
      allow delete: if isSignedIn() && (isOwner(existing().tenantId) || isAdmin());
    }

    match /expenses/{expenseId} {
      allow get: if isSignedIn() && (isOwner(existing().tenantId) || isAdmin());
      allow list: if isSignedIn() && (isOwner(resource.data.tenantId) || isAdmin());
      allow create: if isSignedIn() && isOwner(incoming().tenantId) && isValidExpense(incoming())
        && isValidId(expenseId)
        && incoming().date == request.time;
      allow update: if isAdmin();
      allow delete: if isSignedIn() && (isOwner(existing().tenantId) || isAdmin());
    }

    match /settings/{tenantId} {
      allow get: if isOwner(tenantId) || isAdmin();
      allow create, update: if (isOwner(tenantId) && isValidSettings(incoming())) || isAdmin();
    }

    match /platform/settings {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}

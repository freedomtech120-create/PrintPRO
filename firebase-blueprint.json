{
  "entities": {
    "Tenant": {
      "title": "Tenant",
      "description": "Represents a business using the platform.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isAdmin": { "type": "boolean" },
        "trialExpiresAt": { "type": "string", "format": "date-time" },
        "subscriptionExpiresAt": { "type": "string", "format": "date-time" },
        "isApproved": { "type": "boolean" },
        "subscriptionStatus": { "type": "string", "enum": ["trial", "active", "expired", "pending_approval"] },
        "lastPaymentRef": { "type": "string" },
        "planType": { "type": "string", "enum": ["3m", "6m", "1y"] }
      },
      "required": ["email", "name", "createdAt", "isApproved", "subscriptionStatus"]
    },
    "Order": {
      "title": "Order",
      "description": "Represents an customer order.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "paidAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "completed", "delivered", "cancelled"] },
        "paymentStatus": { "type": "string", "enum": ["unpaid", "partial", "paid"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["tenantId", "customerId", "customerName", "items", "totalAmount", "paidAmount", "status", "paymentStatus", "createdAt", "updatedAt", "createdBy"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Information about a business customer.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" }
      },
      "required": ["tenantId", "name"]
    },
    "Product": {
      "title": "Product",
      "description": "Represents a service or product offered by the business.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "pricePerSqFt": { "type": "number" },
        "category": { "type": "string" }
      },
      "required": ["tenantId", "name", "pricePerSqFt"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Track business spending.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["tenantId", "description", "amount", "category", "date", "createdBy"]
    },
    "BusinessSettings": {
      "title": "BusinessSettings",
      "description": "Configuration for a specific business tenant.",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "website": { "type": "string" },
        "invoicePrefix": { "type": "string" },
        "nextInvoiceNumber": { "type": "number" },
        "currencyCode": { "type": "string" },
        "currencySymbol": { "type": "string" },
        "smsProvider": { "type": "string", "enum": ["arkasel", "mnotify"] },
        "smsApiKey": { "type": "string" },
        "smsSenderId": { "type": "string" },
        "logoUrl": { "type": "string" }
      },
      "required": ["tenantId", "name", "email", "invoicePrefix", "nextInvoiceNumber"]
    },
    "PlatformSettings": {
      "title": "PlatformSettings",
      "description": "Global settings for the administrative platform.",
      "type": "object",
      "properties": {
        "prices": { "type": "object" },
        "currencyCode": { "type": "string" },
        "currencySymbol": { "type": "string" },
        "paystackPublicKey": { "type": "string" }
      },
      "required": ["prices", "currencyCode", "currencySymbol"]
    }
  },
  "firestore": {
    "tenants/{tenantId}": {
      "schema": "Tenant",
      "description": "Individual business profiles."
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Orders created by business tenants."
    },
    "customers/{customerId}": {
      "schema": "Customer",
      "description": "Customers managed by business tenants."
    },
    "products/{productId}": {
      "schema": "Product",
      "description": "Products/services catalog for business tenants."
    },
    "expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Expense logs for business tenants."
    },
    "settings/{tenantId}": {
      "schema": "BusinessSettings",
      "description": "Local settings for each business."
    },
    "platform/settings": {
      "schema": "PlatformSettings",
      "description": "Global settings managed by the platform admin."
    }
  }
}
